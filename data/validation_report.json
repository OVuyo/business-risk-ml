{
  "dataset": "Taiwan Economic Journal - Company Bankruptcy Prediction",
  "source": "https://www.kaggle.com/datasets/fedesoriano/company-bankruptcy-prediction",
  "records": 6819,
  "features": 95,
  "target": "Bankrupt?",
  "class_distribution": {
    "survived": 6599,
    "bankrupt": 220
  },
  "imbalance_ratio": "30:1",
