  "duplicates": 0,
  "outlier_features": 13,
  "top_5_predictors": [
    "Net Income to Total Assets (|r|=0.316)",
    "ROA(A) before interest (|r|=0.283)",
    "ROA(B) before interest (|r|=0.273)",
    "ROA(C) before interest (|r|=0.261)",
    "Debt ratio % (|r|=0.250)"
  ]
}